# Caddyfile - Automatic HTTPS with Let's Encrypt
# Replace yourdomain.com with your actual domain

# 1. Cấu hình cho Frontend
yourdomain.com {
    # Nén dữ liệu [cite: 5]
    encode gzip zstd
    
    # Proxy toàn bộ yêu cầu đến container client
    handle {
        reverse_proxy client:3000
    }

    # Giữ nguyên các header bảo mật của bạn [cite: 2, 3]
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
        -Server
    }

    log {
        output file /var/log/caddy/frontend_access.log
        format json [cite: 5]
    }
}

# 2. Cấu hình cho Backend (API)
api.yourdomain.com {
    encode gzip zstd

    # Proxy các route API và Socket.IO đến container server [cite: 4]
    handle /api/* {
        reverse_proxy server:5000
    }
    
    handle /socket.io/* {
        reverse_proxy server:5000
    }

    # Trả về 404 cho các route không xác định trên subdomain api
    handle {
        abort
    }

    log {
        output file /var/log/caddy/backend_access.log
        format json [cite: 5]
    }
}

# HTTP redirect to HTTPS (automatic, no config needed)
# Caddy automatically redirects HTTP to HTTPS

# Example configuration for multiple domains:
# www.yourdomain.com {
#     redir https://yourdomain.com{uri} permanent
# }
